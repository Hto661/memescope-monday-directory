# Memescope Monday Directory
# Copy to .env.local and fill in values

# ── Database (required for production) ──
# Turso (hosted SQLite) — get at https://turso.tech
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# ── Payments (configure one or both) ──

# NOWPayments — crypto payments, no KYC
# Get keys at https://nowpayments.io → Dashboard → Store Settings
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_IPN_SECRET=

# Stripe — card payments
# Get keys at https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Optional ──

# Site URL for OG tags and payment callbacks
NEXT_PUBLIC_BASE_URL=https://memescope.monday.directory

# Crypto news feed (deploy: github.com/nirholas/free-crypto-news)
CRYPTO_NEWS_API_URL=

# Admin secret for managing submissions
ADMIN_SECRET=
