# Memescope Monday Directory
# Copy to .env.local and fill in values

# Base URL for the site
NEXT_PUBLIC_BASE_URL=https://memescope.monday.directory

# Admin password for managing submissions (optional)
ADMIN_SECRET=your-admin-secret-here

# Stripe secret key for paid features (optional — demo mode without it)
STRIPE_SECRET_KEY=

# Crypto News API (free-crypto-news instance, optional)
# Deploy your own: https://github.com/nirholas/free-crypto-news
CRYPTO_NEWS_API_URL=
